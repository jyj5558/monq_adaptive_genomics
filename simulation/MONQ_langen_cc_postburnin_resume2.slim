//(RESUME+1): reproduction(NULL, "F") {  // after burn-in; Apply to all females
(RESUME+1): reproduction() {
	catn("Entered reproduction() at " + community.tick);

	// Sample nearby locations for potential mates
	females = p0.individuals[p0.individuals.sex == "F" & p0.individuals.age >= 1];
	for (female in females) {
		closest_males_location = DENSITY_MAP.sampleNearbyPoint(female.spatialPosition, SM*3, "n", SM); // efficient version using map

	
	// Find the nearby neighbors at the sampled locations
		closest_males = i2.nearestNeighborsOfPoint(closest_males_location, p0, rpois(1,2)); // twice of targetted values rpois(1,1) assuming 1:1 sex ratio; efficient version using map 
		closest_males = closest_males[closest_males.sex == "M" & closest_males.age >= 1];
	
	// mating process
		for (mate in closest_males) {
			if (!isNULL(mate)) {
				// after map added/changed, the introduced mutation affects fecundity
				if (exists("MUT")) {
					// If mutation exists, calculate effect on fecundity
					mutcount = sum(individual.genomes.containsMutations(MUT));
					// indiv_s and fecundity increase due to it is designed so that selection via mortality and fecundity has the same expected effect size
					indiv_s = 2 * S_FEC * (H_FEC * asFloat(mutcount==1) + asFloat(mutcount==2));
					nOff = rpois(1, 2 * FECUN * (1 + indiv_s) + indiv_s);
				} else {
					// If mutation is not defined, use baseline fecundity
					nOff = rpois(1, 2 * FECUN);
				}
				subpop.addCrossed(female, mate, count = nOff);  // Create offspring
    	    }
		}
	}
	self.active = 0;
}


