RESUME late() {
	// set up logging
	log = community.createLogFile(OUTBASE + 'slim_postburnin' + RESUME + '.log', logInterval=1);
	log.addTick();
	log.addSubpopulationSize(p0);
	log.addCustomColumn('mean_fitness', 'mean(p0.cachedFitness(NULL));');
	log.addCustomColumn('mean_load', 'calcInbreedingLoad(p0.individuals.genomes);');
	log.addCustomColumn('allele_freq', 'return exists("MUT") ? sim.mutationFrequencies(NULL, MUT) else NULL;');
	log.addCustomColumn('pi', 'calcPi(p0.individuals.genomes);');
	//log.addCustomColumn('mean_offspring', 'mean(p0.lifetimeReproductiveOutput);');
	log.addCustomColumn('mean_age', 'mean(p0.individuals.age);');
}

(RESUME+1): first() {
	catn("Entered first() at " + community.tick);

	// move adult individuals
	inds = p0.individuals;
	pos = HABITAT_MAP.sampleImprovedNearbyPoint(inds.spatialPosition, SV*3, "n", SV);
	inds.setSpatialPosition(pos);

	// preparation for the reproduction() callback
	i2.evaluate(p0);
}

(RESUME+1): early() {
	catn("Entered early() at " + community.tick);

	i1.evaluate(p0);

	// disperse offspring
	offspring = p0.subsetIndividuals(maxAge=0);
	//pos = HABITAT_MAP.sampleImprovedNearbyPoint(offspring.spatialPosition, INF, "n", SD); // disperse offsprings following suitable habitats
	//offspring.setSpatialPosition(pos);
	p0.deviatePositions(offspring, "reprising", SD*3, "n", SD); // disperse offsprings randomly
	
	inds = p0.individuals;
	locations = inds.spatialPosition;
	ages = inds.age;
	catn("Number of individuals in p0 after 'early' assignment: " + p0.individualCount);

	// age-dependent mortality
	mortality = L[ages];
	survival = 1 - mortality;

	// local density
	if (USE_GRIDDENSITY) {
		// get raw density and re-smooth for each tick
		density_raw = summarizeIndividuals(inds,
			c(DENSITY_GRID_DIMS[0], DENSITY_GRID_DIMS[1]),
			p0.spatialBounds, operation="individuals.size();",
			empty=0.0, perUnitArea=T);
		DENSITY_MAP.changeValues(density_raw);
		DENSITY_MAP.smooth(SX*3, "n", SX);
		density = p0.spatialMapValue(DENSITY_MAP, locations) / p0.spatialMapValue(LAND_MAP, locations);
	} else {
		density = i1.localPopulationDensity(inds) /  p0.spatialMapValue(LAND_MAP, locations); // the latter normalizes the formal based on inhabitable (land) or uninhabitable (ocean) area
	}
	
	// extract suitability value for each individual
	suitability = HABITAT_MAP.mapValue(inds.spatialPosition);

	//inds.fitnessScaling = 1 / (1 + RHO * density); // density-dependence
	//inds.fitnessScaling = ifelse(suitability == 0.0, 0.0, 1 / (1 + RHO * density) * (0.5 + 0.5 * suitability)); // suitability penalty scaled by 0.5 (0.4766692), the Pearson correlation estimate between point count vs. suitability
	inds.fitnessScaling = ifelse(suitability == 0.0, 0.0, survival * suitability * 1 / (1 + RHO * density)); // suitability penalty * age penality
	inds_to_kill = inds[inds.age >= 3];  // make sure individuals at age 3 defined
	if (size(inds_to_kill) > 0) {
        inds_to_kill.fitnessScaling = 0.0; // Reduce fitness to 0
    }
	//p0.fitnessScaling = min(K_tot / p0.individualCount, 1.0);

	for (i in 0:4) {
    catn("GEN = " + community.tick + " | Individual " + i + " fitnessScaling =  " + inds[i].fitnessScaling);
	}
}

