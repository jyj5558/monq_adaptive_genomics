			defineGlobal("MUT", target.addNewDrawnMutation(m13, asInteger(runif(1, 0, seqLength))));
			catn("Beneficial mutation added at tick " + community.tick);
			catn("Origin point of mutation (x, y): (" + ind.x + ", " + ind.y + ")");
		}
	}
}

