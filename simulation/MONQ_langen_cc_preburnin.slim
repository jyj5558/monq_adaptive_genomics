// Modified by Jong Yoon Jeon from Samarth Mathur's script, Aug 08 2024 
// 2256 genes
// Both deleterious and beneficical
// SLIM=$HOME/app/slim/exe/bin/slim


// Na_0 = 1120000; from Mathur & DeWoody (2023) -> reduced 1/10 while increading 10x for genomic attributes

// Initialize commands to build a genome

initialize() {
	initializeSLiMModelType("nonWF");
	initializeSex("A");
	initializeTreeSeq(simplificationInterval = 1, retainCoalescentOnly = T); 
    
	//setSeed(123); // remove this line and add "-seed 123" when you run slim script on linux

	defaults = Dictionary(
		"USE_GRIDDENSITY", T, // Calculate density in grids (fast) or standard way (slow)
		"FOUNDING_N", 11200, // starting population size; originally 1120000
		"L", c(0.8,0.8,0.2,0.2), // age-related mortality (average of female/male) from Chavarria et al. (2017), Greene (2013) until age of 3
        "K_tot", 11200, // total carrying-capacity for entire range (1/100 from Mathur & DeWoody (2023) or Extent of occurrence = 1,590,000 km² from Bird International or 5696 * 100 km2 from binary habitat suitability map)
		//"K", 1000, // carrying-capacity per unit area converted from 10000 birds/100km2 from several references or 1000 birds/100km2 from Palafox et al. (2007)
		//"SX", 0.418, // SX * 3 = 12.55 km (maximum interaction distance) from below (10km x 10km cell)
		//"SM", 0.418, // SM * 3 = 12.55 km (maximum mating distance) from below (10km x 10km cell)
		//"SD", 0.425, // SD * 3 = 12.74 km (maximum dispersal distance) from Greene et al. 2012 (10km x 10km cell)
		//"SV", 0.418, // SV * 3 = 12.55 km (maximum movement distance) from maximum home range of 15751.36 ha in Greene et al. 2012 (10km x 10km cell)
		"OUTBASE", "/scratch/negishi/jeon96/monq/slim/output_K1000_regular_test2/", // output base directory
		"IMAGEBASE", "/scratch/negishi/jeon96/monq/slim/hsm/", // image input directory
		"DF", 3.0 // Degrees of freedom t dist, appraoches normal as DF -> INF
		);
	
	
	// set up parameters with a user-defined function
	setupParams(defaults);

	// define constants
	defineConstant("g",2256); //number of genes
	defineConstant("geneLength", 1500); // gene length
	defineConstant("seqLength", g*geneLength);
	//defineConstant("ROHcutoff", 10000);
	defineConstant("sampleSize", 100);
	defineConstant("FECUN", 4); // mean number of offsprings of female (offspring-bearer sex) individuals per time step based on the average covey size (8) from Leopold and McCabe 1957)
	defineConstant("S_FEC", 0.1); // selection coefficient for fecundity-based spatial selection
	defineConstant("S_MOR", 0.1); // selection coefficient for mortality-based spatial selection
	defineConstant("H_FEC", 0.5); // dominance coefficient for fecundity-based spatial selection
	defineConstant("H_MOR", 0.5); // dominance coefficient for mortality-based spatial selection
	//defineConstant("RHO", FECUN / ((1 + FECUN) * K)); 
	//defineConstant("WIDTH", 257.0); // width of the simulated area (pixel size -1)
	//defineConstant("HEIGHT", 290.0); // height of the simulated area (pixel size -1) 
	//defineConstant("DENSITY_GRID_DIMS", c(1230, 1386)); // Dimensions used for local density calculation; 2 * p0.spatialBounds / SX
	defineConstant("BURNIN", 112000); // burn-in length; originally 1120000
	//defineConstant("TOTALRUN", 1000000 + 121); // total running
	//defineConstant("CC", seq(1000001, 100121, by = 10));
	//defineConstant("LOCATIONS", OUTBASE + "locations_preburnin.txt"); // location output file
	defineConstant("STATS", OUTBASE + "stats_preburnin.txt"); // stats output file
	defineGlobal("PARAMS", defaults);
	
	// genome details
	initializeMutationRate(3.13597726022324e-07); // originally 3.13597726022324e-09
	
	initializeMutationType("m12", 0.5, "f", 0.0); // neutral mutations
	for (i in 0:5)
		initializeMutationType(i, i * 0.1, "g", -0.314833, 0.186); // deleterious mutations; originally -0.00314833
	for (j in 6:11)
		initializeMutationType(j, (j-6) * 0.1 + 0.5, "g", 0.314833, 0.186); // beneficial mutations (revised from Samarth's); originally -0.00314833
	
	initializeMutationType("m13", H_MOR, "f", S_MOR);
	
	//m0.convertToSubstitution = T;
	//m6.convertToSubstitution = T;
	m12.convertToSubstitution = T;
	initializeGenomicElementType("g1", c(m12,m0,m6), c(1000,231,2.31)); // Gene element. can have neutral, deleterious, or beneficial mutations
	
	gene_nums=c(320,216,180,170,135,82,73,75,72,63,53,51,55,54,48,27,41,43,44,46,31,25,34,26,39,34,51,39,16,43,8,62);
	
	// Set recombination rates:
	// Recombination rate in between "chrosomomes" is 50% (i.e. unlinked).
	// Recombination rate within genes is 0.
	// Recombination rate in between genes is 1e-3, the effective recombination rate for 
	// 100 kb noncoding sequence with a per-site recombination rate of 1e-8 in between 
	// each gene.
	
	for (i in 1:g){
		initializeGenomicElement(g1, ((i-1)*geneLength)+(i-1), (i*geneLength)+(i-2) );
	}
	
	rates=NULL;
	// Multiple chromosomes:
	for (i in 1:(size(gene_nums)-1)){
		rates=c(rates, 0, rep(c(1e-2, 0), asInteger(gene_nums[i-1]-1)), 0.5); // originally 1e-4
	}
	rates=c(rates, 0, rep(c(1e-2, 0), asInteger(gene_nums[size(gene_nums)-1]-1))); // originally 1e-4
	
	ends=NULL;
	for (i in 1:g){
		ends=c(ends, (i*geneLength)+(i-2), (i*geneLength)+(i-1));
	}
	ends=ends[0:(size(ends)-2)];
	
	initializeRecombinationRate(rates, ends);

}

mutation(m0) {
	s = mut.selectionCoeff;
	d = 5 - asInteger(min(floor(abs(s) * 10.0), 5.0)); // originally 1000.0
	mut.setMutationType(d);
	return T;
}

mutation(m6) {
	s = mut.selectionCoeff;
	d = 6 + asInteger(min(floor(abs(s) * 10.0), 5.0)); // originally 1000.0
	mut.setMutationType(d);
	return T;
}

// define function getStats that randomly samples a subpopulation for sampSize # of inds and outputs a string of: 
// pop size, mean fitness, heterozygosity, mean Froh, and avg num of variants of different classes per individual (very str del, str del, mod del, wk del, very str ben, str ben, mod ben, wk ben)

function (s) getStats(o pop, i sampSize) //modified from Chris Kyriazis's version
{	
	actual_sampSize = min(sampSize, pop.individuals.size());
	i = sample(pop.individuals, actual_sampSize, F);
	
	m = sortBy(i.genomes.mutations, "position"); //get all mutations in sample
	m_uniq = unique(m); // get rid of redundant muts

	//DAF = sapply(m_uniq, "sum(m == applyValue);"); // count number of each mut in pop
	indices_in_m_uniq = match(m, m_uniq);
	DAF = tabulate(indices_in_m_uniq, size(m_uniq)-1);

	m_uniq_polym = m_uniq[DAF != i.genomes.size()]; //remove fixed mutations??
	nonben_muts = m_uniq[m_uniq.mutationType == m0 | m_uniq.mutationType == m1 | m_uniq.mutationType == m2 | m_uniq.mutationType == m3 | m_uniq.mutationType == m4 | m_uniq.mutationType == m5 | m_uniq.mutationType == m12];
	
	//initialize vectors
	ROH_length_sumPerInd_10Mb = c();
	ROH_length_sumPerInd_1Mb = c();
	ROH_length_sumPerInd_500Kb = c();
    ROH_length_sumPerInd_100Kb = c();
	Num_vstrDel_muts = c();
	Num_strDel_muts = c();
	Num_modDel_muts = c();
	Num_wkDel_muts = c();
	Num_neut_muts = c();
	Num_vstrBen_muts = c();
	Num_strBen_muts = c();
	Num_modBen_muts = c();
	Num_wkBen_muts = c();
	ind_het = c();
	//B_pop = c();
	//fitness_population = c();
	LoadP_high_ind = c();
	LoadP_mod_ind = c();
	LoadP_low_ind = c();
	LoadP_tot_ind = c();
	LoadR_high_ind = c();
	LoadR_mod_ind = c();
	LoadR_low_ind = c();
	LoadR_tot_ind = c();
		
	for (individual in i) {
		
		indm = sortBy(individual.genomes.mutations, "position");
		indm = indm[match(indm, m_uniq_polym) >= 0];   // Check that individual mutations are not fixed 
		indm_uniq = unique(indm);
		
		genotype = sapply(indm_uniq, "sum(indm == applyValue);");
		
		// tally number of mutations for different classes of selection coefficient per individual
		s = individual.genomes.mutations.selectionCoeff;
		
		Num_vstrDel_muts = c(Num_vstrDel_muts, sum(s<=-.5)); 
		Num_strDel_muts = c(Num_strDel_muts, sum(s<=-1 & s > -5));
		Num_modDel_muts = c(Num_modDel_muts, sum(s<=-0.1 & s > -1));
		Num_wkDel_muts = c(Num_wkDel_muts, sum(s<=-0.001 & s > -0.1));
		Num_neut_muts = c(Num_neut_muts, sum(s==0.0));
		Num_vstrBen_muts = c(Num_vstrBen_muts, sum(s>=5));
		Num_strBen_muts = c(Num_strBen_muts, sum(s>=1 & s < 5));
		Num_modBen_muts = c(Num_modBen_muts, sum(s>=0.1 & s < 1));
		Num_wkBen_muts = c(Num_wkBen_muts, sum(s>=0.001 & s < 0.1));
		
		if (isNULL(genotype)) {
			ind_het = c(ind_het, 0); //putting this here to avoid error when trying to sum null vector
			next;
		}
		
		ind_het = c(ind_het, sum(genotype==1)/(seqLength));
		
		//code for getting ROHs 
		
		ID_het = (genotype == 1); //outputs T/F for genotypes if they are het or homDer
		ID_homDer = (genotype == 2);
		pos_het = indm_uniq.position[ID_het]; //outputs positions of heterozgoys genotypes
		
		startpos = c(0, pos_het); //adds 0 to beggining of vector of hets
		endpos = c(pos_het, sim.chromosome.lastPosition); //adds last position in genome to vector of hets
		pos_het_diff = endpos - startpos;

        //sum for ROHs > 10Mb
        ROH_startpos_10Mb = startpos[pos_het_diff > 10000000]; //filter out startpos that dont correspond to ROH > 10Mb
        ROH_endpos_10Mb = endpos[pos_het_diff > 10000000];
        ROH_length_10Mb = pos_het_diff[pos_het_diff > 10000000]; //vector of ROHs for each individual
        ROH_length_sum_10Mb = sum(ROH_length_10Mb);
        ROH_length_sumPerInd_10Mb = c(ROH_length_sumPerInd_10Mb, ROH_length_sum_10Mb); // add sum of ROHs for each individual to vector of ROHs for all individuals
		
		//sum for ROHs > 1Mb
		ROH_startpos_1Mb = startpos[pos_het_diff > 1000000]; //filter out startpos that dont correspond to ROH > 1Mb
		ROH_endpos_1Mb = endpos[pos_het_diff > 1000000];
		ROH_length_1Mb = pos_het_diff[pos_het_diff > 1000000]; //vector of ROHs for each individual	
		ROH_length_sum_1Mb = sum(ROH_length_1Mb);
		ROH_length_sumPerInd_1Mb = c(ROH_length_sumPerInd_1Mb, ROH_length_sum_1Mb); // add sum of ROHs for each individual to vector of ROHs for all individuals
		
		//sum for ROHs > 500kb
		ROH_startpos_500Kb = startpos[pos_het_diff > 500000]; //filter out startpos that dont correspond to ROH > 500 Kb
		ROH_endpos_500Kb = endpos[pos_het_diff > 500000];
		ROH_length_500Kb = pos_het_diff[pos_het_diff > 500000]; //vector of ROHs for each individual	
		ROH_length_sum_500Kb = sum(ROH_length_500Kb);
		ROH_length_sumPerInd_500Kb = c(ROH_length_sumPerInd_500Kb, ROH_length_sum_500Kb); // add sum of ROHs for each individual to vector of ROHs for all individuals

        //sum for ROHs > 100kb
        ROH_startpos_100Kb = startpos[pos_het_diff > 100000]; //filter out startpos that dont correspond to ROH > 100 Kb
        ROH_endpos_100Kb = endpos[pos_het_diff > 100000];
        ROH_length_100Kb = pos_het_diff[pos_het_diff > 100000]; //vector of ROHs for each individual
        ROH_length_sum_100Kb = sum(ROH_length_100Kb);
        ROH_length_sumPerInd_100Kb = c(ROH_length_sumPerInd_100Kb, ROH_length_sum_100Kb); // add sum of ROHs for each individual to vector of ROHs for all individuals
		
		//calculate 2B (inbreeding load)
		del_muts = c(individual.genomes.mutationsOfType(m0),individual.genomes.mutationsOfType(m1),individual.genomes.mutationsOfType(m2),individual.genomes.mutationsOfType(m3),individual.genomes.mutationsOfType(m4),individual.genomes.mutationsOfType(m5));
		//B_ind = c();
		
		if (del_muts.length()>0) {
			//for(m in del_muts){
				//check if mut is heterozygous
			//	if(individual.genomes.mutationCountsInGenomes(m) == 1){
					
					//protect against case where s < -1 (can happen with gamma DFE)
			//		s = max(m.selectionCoeff,-1.0);
					//difference in fitness between het and hom is s*(h-1) (i.e., 1+sh -(1+s))
			//		B_ind = c(B_ind, s*(m.mutationType.dominanceCoeff-1));
					//catn(m.id + "," +  m.selectionCoeff + "," + m.selectionCoeff*(m.mutationType.dominanceCoeff-1));
			//	}
				
			//}

			//if(isNULL(B_ind)){
			//	B_pop = c(B_pop, 0.0);
			//}
			// this is summed rather than multiplied
			//even if fitness is multiplicative
			//else{
			//	B_pop = c(B_pop, sum(B_ind));
			//}

			//chek if mut copy exists
			high_muts_ind = c(individual.genomes.mutationsOfType(m0), individual.genomes.mutationsOfType(m1));
			mod_muts_ind  = c(individual.genomes.mutationsOfType(m2), individual.genomes.mutationsOfType(m3));
			low_muts_ind  = c(individual.genomes.mutationsOfType(m4), individual.genomes.mutationsOfType(m5));
			tot_muts_ind  = del_muts;

			// Potential load: just count
			LoadP_high_ind = c(LoadP_high_ind, size(high_muts_ind) / max(1, size(nonben_muts)));
			LoadP_mod_ind = c(LoadP_mod_ind, size(mod_muts_ind) / max(1, size(nonben_muts)));
			LoadP_low_ind = c(LoadP_low_ind, size(low_muts_ind) / max(1, size(nonben_muts)));
			LoadP_tot_ind = c(LoadP_tot_ind, size(tot_muts_ind) / max(1, size(nonben_muts)));

			// Realized load: homozygous mutations
			tmp_high = sapply(high_muts_ind, "individual.genomes.mutationCountsInGenomes(applyValue) == 2;");
			hom_high_ind = isNULL(tmp_high) ? 0 else sum(tmp_high);
			tmp_mod = sapply(mod_muts_ind, "individual.genomes.mutationCountsInGenomes(applyValue) == 2;");
			hom_mod_ind = isNULL(tmp_mod) ? 0 else sum(tmp_mod);
			tmp_low = sapply(low_muts_ind, "individual.genomes.mutationCountsInGenomes(applyValue) == 2;");
			hom_low_ind = isNULL(tmp_low) ? 0 else sum(tmp_low);
			tmp_tot = sapply(tot_muts_ind, "individual.genomes.mutationCountsInGenomes(applyValue) == 2;");
			hom_tot_ind = isNULL(tmp_tot) ? 0 else sum(tmp_tot);
			site_high_ind = 2 * size(isNULL(high_muts_ind) ? 0 else unique(high_muts_ind));
			site_mod_ind  = 2 * size(isNULL(mod_muts_ind) ? 0 else unique(mod_muts_ind));
			site_low_ind  = 2 * size(isNULL(low_muts_ind) ? 0 else unique(low_muts_ind));
			site_tot_ind = 2 * size(isNULL(tot_muts_ind) ? 0 else unique(tot_muts_ind));
			LoadR_high_ind = c(LoadR_high_ind, hom_high_ind / max(1, site_high_ind));
			LoadR_mod_ind  = c(LoadR_mod_ind, hom_mod_ind  / max(1, site_mod_ind));
			LoadR_low_ind  = c(LoadR_low_ind, hom_low_ind  / max(1, site_low_ind));
			LoadR_tot_ind = c(LoadR_tot_ind, hom_tot_ind / max(1, site_tot_ind));
		}
	
	}

	//all_muts = pop.genomes.mutations;
	//nonben_muts = all_muts[all_muts.mutationType == m0 | all_muts.mutationType == m1 | all_muts.mutationType == m2 | all_muts.mutationType == m3 | all_muts.mutationType == m4 | all_muts.mutationType == m5];
	//LoadP_high_pop = isNULL(LoadP_high_ind) ? 0.0 else sum(LoadP_high_ind) / max(1, size(nonben_muts));
	//LoadP_mod_pop = isNULL(LoadP_mod_ind) ? 0.0 else sum(LoadP_mod_ind) / max(1, size(nonben_muts));
	//LoadP_low_pop = isNULL(LoadP_low_ind) ? 0.0 else sum(LoadP_low_ind) / max(1, size(nonben_muts));
	//LoadP_tot_pop = isNULL(LoadP_tot_ind) ? 0.0 else sum(LoadP_tot_ind) / max(1, size(nonben_muts));
	mean_LoadP_high_ind = isNULL(LoadP_high_ind) ? 0.0 else mean(LoadP_high_ind);
	mean_LoadP_mod_ind = isNULL(LoadP_mod_ind) ? 0.0 else mean(LoadP_mod_ind);
	mean_LoadP_low_ind = isNULL(LoadP_low_ind) ? 0.0 else mean(LoadP_low_ind);
	mean_LoadP_tot_ind = isNULL(LoadP_tot_ind) ? 0.0 else mean(LoadP_tot_ind);

	mean_LoadR_high_ind = isNULL(LoadR_high_ind) ? 0.0 else mean(LoadR_high_ind);
	mean_LoadR_mod_ind = isNULL(LoadR_mod_ind) ? 0.0 else mean(LoadR_mod_ind);
	mean_LoadR_low_ind = isNULL(LoadR_low_ind) ? 0.0 else mean(LoadR_low_ind);
	mean_LoadR_tot_ind = isNULL(LoadR_tot_ind) ? 0.0 else mean(LoadR_tot_ind);

	return(pop.individuals.size() + "," + mean(pop.cachedFitness(NULL)) + "," + mean(ind_het) + "," + calcInbreedingLoad(pop.individuals.genomes) + "," + mean(ROH_length_sumPerInd_100Kb)/seqLength + "," +  mean(ROH_length_sumPerInd_500Kb)/seqLength + "," + mean(ROH_length_sumPerInd_1Mb)/seqLength + "," + mean(ROH_length_sumPerInd_10Mb)/seqLength + "," +  mean(Num_vstrDel_muts) + "," + mean(Num_strDel_muts)+ "," + mean(Num_modDel_muts) + "," + mean(Num_wkDel_muts)+ "," + mean(Num_vstrBen_muts) + "," + mean(Num_strBen_muts) + "," + mean(Num_modBen_muts) + "," + mean(Num_wkBen_muts) + "," + mean(Num_neut_muts) + "," + mean_LoadP_high_ind + "," + mean_LoadP_mod_ind + "," + mean_LoadP_low_ind+ "," + mean_LoadP_tot_ind + "," + mean_LoadR_high_ind + "," + mean_LoadR_mod_ind + "," + mean_LoadR_low_ind + "," + mean_LoadR_tot_ind);
}


