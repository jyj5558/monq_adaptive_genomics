1:BURNIN late() {
	//if (community.tick % 10 == 0) {
    sim.treeSeqSimplify();
	//}
	if (community.tick % 10000 == 0) {
    sim.treeSeqOutput(OUTBASE + "pregenome" + community.tick + ".trees");
	sim.outputFull(OUTBASE + "preburnin" + community.tick + ".slim");
	}
}

BURNIN late() {
	catn("End of simulation (run time reached)");
	sim.treeSeqOutput(OUTBASE + "pregenome" + community.tick + ".trees");
	sim.outputFull(OUTBASE + "preburnin" + community.tick + ".slim");
	sim.simulationFinished();
}

reproduction() {
	catn("Entered reproduction() at " + community.tick);

	// Sample nearby locations for potential mates
	females = p0.individuals[p0.individuals.sex == "F" & p0.individuals.age >= 1];
	males = p0.individuals[p0.individuals.sex == "M" & p0.individuals.age >= 1];

	for (female in females) {
		mates = sample(males, rpois(1,1), replace = F);
	
	// mating process
		for (mate in mates) {
			if (!isNULL(mate)) {
				// after map added/changed, the introduced mutation affects fecundity
				nOff = rpois(1, 2 * FECUN);
				}
				subpop.addCrossed(female, mate, count = nOff);  // Create offspring
    	    }
	}
	self.active = 0;
}


function (void)setupParams(object<Dictionary>$ defaults)
{
	if (!exists("PARAMFILE")) defineConstant("PARAMFILE", "./params.json");
	if (!exists("OUTDIR")) defineConstant("OUTDIR", ".");
	defaults.addKeysAndValuesFrom(Dictionary("PARAMFILE", PARAMFILE, "OUTDIR", OUTDIR));
	
	if (fileExists(PARAMFILE)){
		defaults.addKeysAndValuesFrom(Dictionary(readFile(PARAMFILE)));
		defaults.setValue("READ_FROM_PARAMFILE", PARAMFILE);
	}
	
	//defaults.setValue("OUTBASE", OUTDIR + "/out_" +	defaults.getValue("seed"));
	//defaults.setValue("OUTPATH", defaults.getValue("OUTBASE") + ".trees");
	
	for (k in defaults.allKeys) {
		if (!exists(k))
			defineConstant(k, defaults.getValue(k));
		else
			defaults.setValue(k, executeLambda(paste(c(k, ";"), sep='')));
	}
	
	// print out default values
	catn("===========================");
	catn("Model constants: " + defaults.serialize("pretty"));
	catn("===========================");
}
