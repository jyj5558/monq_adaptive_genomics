early() {
    inds = p0.individuals;
    
	ages = inds.age;
	
    // age-dependent mortality
	mortality = L[ages];
	survival = 1 - mortality;

    inds.fitnessScaling = survival; // age penality
    	inds_to_kill = inds[inds.age >= 3];  // make sure individuals at age 3 defined
	if (size(inds_to_kill) > 0) {
        inds_to_kill.fitnessScaling = 0.0; // Reduce fitness to 0
    }
}

late() {
	inds = p0.individuals;
	ind_count = size(inds);

	if (ind_count > K_tot) { // WF model-like approach fixing the total number of individuals
        // If the population size is greater than the fixed target, cull the excess randomly.
        num_to_kill = ind_count - K_tot;
        
        // Randomly sample 'num_to_kill' individuals from the current population
        individuals_to_cull = sample(inds, num_to_kill, replace=F);
        
        // Immediately remove these selected individuals from the simulation
        sim.killIndividuals(individuals_to_cull); 
    }

	if (p0.individualCount == 0) {
		catn("Population went extinct! Ending the simulation.");
		sim.simulationFinished();
	}
}

