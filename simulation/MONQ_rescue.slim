        inds_to_kill.fitnessScaling = 0.0; // Reduce fitness to 0
    }

	indLen = pmin(4, p3.individualCount);
	for (i in 0:indLen) {
    catn("GEN = " + community.tick + " | Individual " + i + " of p3's fitnessScaling =  " + inds[i].fitnessScaling);
	}
}

// send migrant(s) to p1 from p2
(BURNIN+11):TOTALRUN early() {   
	if ((community.tick - (BURNIN+10)) % INTERVAL == 0) {   
        if(sim.getValue("rescueCount") < numRes) {
            all_subs = sim.subpopulations;
			source_pop = all_subs[all_subs.name == SOURCE]; //source_pop = sim.subpopulationsWithNames(SOURCE);
            migrants = sample(source_pop.individuals, numMig);
			migrants.genomes.addNewDrawnMutation(m14, M14_POSITIONS);
			migrants.genomes.addNewDrawnMutation(m14, FIXED_A_POSITIONS); // Apply markers to A sites 
			migrants.genomes.addNewDrawnMutation(m14, G_SITES); // Apply markers to G sites

            p1.takeMigrants(migrants);
			sim.setValue("rescueCount", sim.getValue("rescueCount")+1);

            catn("The genetic rescue happend at generation: " + community.tick + " with " + numMig + " individuals from " + SOURCE);
        }
    }
}

// remove p2 and p3
(BURNIN + 10 + numRes * INTERVAL + 1) early() {
    p2.removeSubpopulation();
    p3.removeSubpopulation();
    
    catn("Subpopulations p2 and p3 have been removed at " + community.tick);
}

(BURNIN + 10 + numRes * INTERVAL + 1): early() {
	catn("Entered early() at " + community.tick);

	inds = p1.individuals;
	ages = inds.age;
	catn("Number of individuals in p1 after 'early' assignment: " + p1.individualCount);

	// age-dependent mortality
	//mortality = L[ages];
	//survival = 1 - mortality;

	//inds.fitnessScaling = survival * K_p1 / p1.individualCount;
	inds.fitnessScaling = K_p1 / p1.individualCount;
	inds_to_kill = inds[inds.age >= 3];  // make sure individuals at age 3 defined
	if (size(inds_to_kill) > 0) {
        inds_to_kill.fitnessScaling = 0.0; // Reduce fitness to 0
    }

	indLen = pmin(4, p1.individualCount);
	for (i in 0:indLen) {
    catn("GEN = " + community.tick + " | Individual " + i + " of p1's fitnessScaling =  " + inds[i].fitnessScaling);
	}
}

// tracking block: runs every tick
(BURNIN+12):TOTALRUN late() {
    // only track after genetic rescue initiated
        
    // A. Genome-Wide Proportion
    // Get all m14 mutations currently segregating in p1
    muts_m14 = p1.genomes.mutationsOfType(m14);

	// Filter for mutations that are at genome-wide marker locations
	is_target_marker = match(muts_m14.position, M14_POSITIONS) >= 0;
	target_muts = muts_m14[is_target_marker];
        
    // Calculate proportion
    if (target_muts.size() > 0) {
		count_target = target_muts.size();
    	prop_genome = count_target / (TOTAL_M14_SITES * p1.genomes.size());
	} else {
    	prop_genome = 0.0;
	}

	// B. Proportion at Ancestral "A" Sites
    // 1. Get all m14 mutations currently segregating in p1
    //muts_m14 = p1.genomes.mutationsOfType(m14);
        
    // 2. Filter for mutations that are at A_SITES
    // (match returns indices of matches; >=0 means it is a A site)
    // Note: For large genomes, this check can be slow. 
    is_at_A = match(muts_m14.position, FIXED_A_POSITIONS) >= 0;
    a_muts = muts_m14[is_at_A];
        
    // 3. Sum the counts (prevalence) of these specific A-site markers
    if (a_muts.size() > 0) {
        count_A = a_muts.size();
		prop_A = count_A / (TOTAL_FIXED_A_SITES * p1.genomes.size());
    } else {
        prop_A = 0.0;
    }

    catn("Tick " + community.tick + ": Ancestry(Genome)=" + prop_genome + 
    	", Ancestry(A-sites)=" + prop_A);
        
    // C. Proportion at Ancestral "G" Sites
    // 1. Get all m14 mutations currently segregating in p1
    //muts_m14 = p1.genomes.mutationsOfType(m14); done above
        
    // 2. Filter for mutations that are at G_SITES
    // (match returns indices of matches; >=0 means it is a G site)
    // Note: For large genomes, this check can be slow. 
    is_at_G = match(muts_m14.position, G_SITES) >= 0;
    g_muts = muts_m14[is_at_G];
        
    // 3. Sum the counts (prevalence) of these specific G-site markers
    if (g_muts.size() > 0) {
        count_G = g_muts.size();
        prop_G = count_G / (TOTAL_G_SITES * p1.genomes.size());
    } else {
        prop_G = 0.0;
    }

    catn("Tick " + community.tick + ": Ancestry(Genome)=" + prop_genome + 
        ", Ancestry(G-sites)=" + prop_G);

	p1.setValue("migrant_prop_genome", prop_genome);
	p1.setValue("migrant_prop_A", prop_A);
    p1.setValue("migrant_prop_G", prop_G);
}

