mutationEffect(m13, p1) {
    // extract stored s coefficient
    s = mut.getValue("s_p1");
    
    // default fitness value = 1.0
    if (isNULL(s)) return 1.0;

    if (homozygous) {
        return 1.0 + s;
	} else {
		h = mut.getValue("h_p1");
		if (isNULL(h)) h = 0.5; 
        return 1.0 + h * s;
	}
}

