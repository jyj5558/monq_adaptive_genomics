early() {
	catn("Entered early() at " + community.tick);

	inds = p1.individuals;
	ages = inds.age;
	catn("Number of individuals in p1 after 'early' assignment: " + p1.individualCount);

	// age-dependent mortality
	mortality = L[ages];
	survival = 1 - mortality;

	inds.fitnessScaling = survival * K_p1 / p1.individualCount;
	inds_to_kill = inds[inds.age >= 3];  // make sure individuals at age 3 defined
	if (size(inds_to_kill) > 0) {
        inds_to_kill.fitnessScaling = 0.0; // Reduce fitness to 0
    }

	indLen = pmin(4, p1.individualCount);
	for (i in 0:indLen) {
    catn("GEN = " + community.tick + " | Individual " + i + "of p1's fitnessScaling =  " + inds[i].fitnessScaling);
	}

